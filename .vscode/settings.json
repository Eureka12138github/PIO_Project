{
  "editor.formatOnSave": true,
  "json.schemaDownload.enable": false,
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    }
  },
  "markdownlint.config": {
    "default": true,
    "MD013": false,
    "MD024": false,
    "MD041": false,
    "MD060": false
  }
}